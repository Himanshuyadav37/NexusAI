        "jsonBody": "={\n  \"sender\": {\n    \"name\": \"NexusAI\",\n    \"email\": \"ydvhimanshu461@gmail.com\"\n  },\n  \"to\": [\n    {\n      \"email\": \"{{ $json.body.email }}\",\n      \"name\": \"{{ $json.body.username || 'Developer' }}\"\n    }\n  ],\n  \"subject\": \"{{ $json.body.code }} — NexusAI Login Code\",\n  \"htmlContent\": \"<div style=\\\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 600px; margin: 0 auto; padding: 40px 30px; border: 1px solid #1e293b; border-radius: 16px; background-color: #0f172a; color: #ffffff;\\\">\\n  <div style=\\\"text-align: center; margin-bottom: 30px;\\\">\\n    <h1 style=\\\"color: #8b5cf6; margin: 0; font-size: 32px; font-weight: 800; letter-spacing: -0.05em;\\\">NexusAI<span style=\\\"color: #38bdf8;\\\">.AI</span></h1>\\n    <p style=\\\"color: #94a3b8; margin: 5px 0 0 0; font-size: 14px;\\\">Autonomous Multi-Agent AI Operating System</p>\\n  </div>\\n  \\n  <div style=\\\"background: linear-gradient(90deg, #8b5cf6 0%, #38bdf8 100%); height: 4px; border-radius: 2px; margin-bottom: 30px;\\\"></div>\\n  \\n  <h2 style=\\\"color: #ffffff; margin-top: 0; font-size: 24px; font-weight: 700; text-align: center;\\\">Verification Code</h2>\\n  \\n  <p style=\\\"color: #cbd5e1; font-size: 16px; line-height: 1.6; text-align: center; margin-bottom: 25px;\\\">\\n    Hi {{ $json.body.username || 'Developer' }},<br>\\n    Use the 6-digit code below to securely sign in to your NexusAI workspace:\\n  </p>\\n  \\n  <div style=\\\"text-align: center; margin: 30px 0;\\\">\\n    <div style=\\\"display: inline-block; background: rgba(139, 92, 246, 0.1); border: 2px solid #8b5cf6; border-radius: 12px; padding: 18px 40px; font-size: 36px; font-weight: 800; letter-spacing: 6px; color: #a78bfa; font-family: monospace; box-shadow: 0 4px 20px rgba(139, 92, 246, 0.15);\\\">\\n      {{ $json.body.code }}\\n    </div>\\n  </div>\\n  \\n  <p style=\\\"color: #94a3b8; font-size: 14px; text-align: center; margin-bottom: 30px;\\\">\\n    This code will expire in <strong>10 minutes</strong>. If you did not request this verification, you can safely ignore this email.\\n  </p>\\n  \\n  <hr style=\\\"border: 0; border-top: 1px solid #1e293b; margin: 30px 0 20px 0;\\\" />\\n  \\n  <p style=\\\"color: #64748b; font-size: 12px; text-align: center; margin: 0;\\\">\\n    This email was sent to {{ $json.body.email }} because you requested to sign in.<br>\\n    &copy; 2026 NexusAI AI. All rights reserved.\\n  </p>\\n</div>\"\n}"
      },
